# ============================================================
# Variables de Entorno para Railway (PRODUCTION)
# ============================================================
# Copia estas variables al panel de Railway > Service > Variables
#
# IMPORTANTE: El archivo .env local NO se sube a Railway.
# Debes configurar estas variables en el panel de Railway.
# ============================================================

# --- BASE DE DATOS ---
# Para SQLite en Railway con Volumen montado en /data:
DATABASE_URL=file:/data/vmp.db

# Para PostgreSQL (si lo usás):
# DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# --- JWT (¡CAMBIA ESTO EN PRODUCCIÓN!) ---
JWT_SECRET=vmp-secret-key-SUPER-SEGURO-CAMBIAR-2026

# --- FRONTEND ---
FRONTEND_URL=https://vmp-edtech-next-final.vercel.app

# --- ENTORNO ---
ENVIRONMENT=production

# --- CORS (URLs del frontend separadas por comas) ---
CORS_ORIGINS=https://vmp-edtech-next-final.vercel.app,https://vmpservicios.com,https://www.vmpservicios.com

# --- STORAGE (Volumen de Railway montado) ---
STORAGE_PATH=/data/storage

# --- EMAIL (SendGrid) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=TU_SENDGRID_API_KEY
EMAIL_FROM=noreply@vmpservicios.com
EMAIL_VENTAS=ventas@vmpservicios.com

# --- ADMIN ---
ADMIN_URL=https://vmp-edtech-next-final.vercel.app
