generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = "5"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                        String              @id @default(uuid())
  email                                     String              @unique
  passwordHash                              String              @map("password_hash")
  nombre                                    String
  apellido                                  String
  dni                                       String              @unique
  telefono                                  String?
  rol                                       UserRole            @default(ALUMNO)
  empresaId                                 String?             @map("empresa_id")
  avatar                                    String?
  activo                                    Boolean             @default(true)
  createdAt                                 DateTime            @default(now()) @map("created_at")
  updatedAt                                 DateTime            @updatedAt @map("updated_at")
  meetLink                                  String?             @map("meet_link")
  asistencias_clase                         asistencias_clase[]
  credenciales                              Credencial[]
  evidencias_evidencias_alumno_idTousers    evidencias[]        @relation("evidencias_alumno_idTousers")
  evidencias_evidencias_evaluador_idTousers evidencias[]        @relation("evidencias_evaluador_idTousers")
  examenes                                  Examen[]
  fotoCredencial                            FotoCredencial?     @relation("AlumnoFoto")
  fotosEvaluadas                            FotoCredencial[]    @relation("EvaluadorFoto")
  inscripciones                             Inscripcion[]
  empresa                                   Company?            @relation(fields: [empresaId], references: [id])

  @@index([rol])
  @@index([empresaId])
  @@map("users")
}

model Company {
  id        String   @id @default(uuid())
  nombre    String
  cuit      String   @unique
  direccion String?
  telefono  String?
  email     String
  activa    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  cursos    Curso[]
  usuarios  User[]
  ventas    Venta[]

  @@map("companies")
}

model Curso {
  id            String        @id @default(uuid())
  nombre        String
  descripcion   String
  codigo        String        @unique
  duracionHoras Int           @map("duracion_horas")
  vigenciaMeses Int?          @map("vigencia_meses")
  empresaId     String?       @map("empresa_id")
  activo        Boolean       @default(true)
  meetingLink     String?       @map("meeting_link")
  meetingPlatform String?       @map("meeting_platform") // "zoom", "teams", "meet"
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  credenciales  Credencial[]
  empresa       Company?      @relation(fields: [empresaId], references: [id])
  examenes      Examen[]
  inscripciones Inscripcion[]
  modulos       Modulo[]

  @@map("cursos")
}

model Modulo {
  id                String              @id @default(uuid())
  cursoId           String              @map("curso_id")
  titulo            String
  orden             Int
  tipo              TipoModulo
  contenidoHtml     String?             @map("contenido_html")
  videoUrl          String?             @map("video_url")
  liveClassUrl      String?             @map("live_class_url")
  liveClassDate     DateTime?           @map("live_class_date")
  liveClassPlatform String?             @map("live_class_platform")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  asistencias_clase asistencias_clase[]
  curso             Curso               @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  preguntas         Pregunta[]
  tareas_practicas  tareas_practicas[]

  @@map("modulos")
}

model Pregunta {
  id                String   @id @default(uuid())
  moduloId          String   @map("modulo_id")
  pregunta          String
  opciones          Json
  respuestaCorrecta Int      @map("respuesta_correcta")
  explicacion       String?
  createdAt         DateTime @default(now()) @map("created_at")
  modulo            Modulo   @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@map("preguntas")
}

model Inscripcion {
  id         String            @id @default(uuid())
  alumnoId   String            @map("alumno_id")
  cursoId    String            @map("curso_id")
  progreso   Int               @default(0)
  estado     EstadoInscripcion @default(NO_INICIADO)
  inicioDate DateTime?         @map("inicio_date")
  finDate    DateTime?         @map("fin_date")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  alumno     User              @relation(fields: [alumnoId], references: [id])
  curso      Curso             @relation(fields: [cursoId], references: [id])

  @@unique([alumnoId, cursoId])
  @@index([estado])
  @@index([alumnoId])
  @@index([cursoId])
  @@map("inscripciones")
}

model Examen {
  id           String   @id @default(uuid())
  alumnoId     String   @map("alumno_id")
  cursoId      String   @map("curso_id")
  respuestas   Json
  calificacion Float?
  aprobado     Boolean?
  realizadoAt  DateTime @default(now()) @map("realizado_at")
  modulo_id    String?
  alumno       User     @relation(fields: [alumnoId], references: [id])
  curso        Curso    @relation(fields: [cursoId], references: [id])

  @@index([alumnoId])
  @@index([cursoId])
  @@index([modulo_id])
  @@map("examenes")
}

model FotoCredencial {
  id          String          @id @default(uuid())
  alumnoId    String          @unique @map("alumno_id")
  fotoUrl     String          @map("foto_url")
  comentario  String?
  estado      EstadoEvidencia @default(PENDIENTE)
  feedback    String?
  evaluadorId String?         @map("evaluador_id")
  uploadedAt  DateTime        @default(now()) @map("uploaded_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  alumno      User            @relation("AlumnoFoto", fields: [alumnoId], references: [id], onDelete: Cascade)
  evaluador   User?           @relation("EvaluadorFoto", fields: [evaluadorId], references: [id])

  @@map("fotos_credencial")
}

model Credencial {
  id               String    @id @default(uuid())
  numero           String    @unique
  alumnoId         String    @map("alumno_id")
  cursoId          String    @map("curso_id")
  pdfUrl           String    @map("pdf_url")
  qrCodeUrl        String    @map("qr_code_url")
  fechaEmision     DateTime  @default(now()) @map("fecha_emision")
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  createdAt        DateTime  @default(now()) @map("created_at")
  alumno           User      @relation(fields: [alumnoId], references: [id])
  curso            Curso     @relation(fields: [cursoId], references: [id])

  @@index([alumnoId])
  @@index([cursoId])
  @@index([numero])
  @@map("credenciales")
}

model Cotizacion {
  id              Int      @id @default(autoincrement())
  empresa         String
  cuit            String?
  nombre          String
  email           String
  telefono        String
  comentarios     String?
  quantity        Int
  course          String
  modality        String
  totalPrice      Float    @map("total_price")
  pricePerStudent Float    @map("price_per_student")
  discount        Int
  acceptMarketing Boolean  @default(false) @map("accept_marketing")
  acceptTerms     Boolean  @default(false) @map("accept_terms")
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("cotizaciones")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Account {
  id            String        @id @default(uuid())
  code          String        @unique
  name          String
  type          String
  parentCode    String?       @map("parent_code")
  level         Int?          @default(1)
  isSelectable  Boolean?      @default(true) @map("is_selectable")
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  ledgerEntries LedgerEntry[]

  @@map("accounts")
}

model JournalEntry {
  id        String        @id @default(uuid())
  date      DateTime?     @default(now()) @db.Timestamp(6)
  concept   String
  reference String?
  type      String?       @default("GENERAL")
  createdAt DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  entries   LedgerEntry[]

  @@map("journal_entries")
}

model LedgerEntry {
  id          String        @id @default(uuid())
  journalId   String?       @map("journal_id")
  accountId   String?       @map("account_id")
  description String?
  debit       Float?        @default(0)
  credit      Float?        @default(0)
  createdAt   DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  account     Account?      @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  journal     JournalEntry? @relation(fields: [journalId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("ledger_entries")
}

model Venta {
  id           String      @id @default(uuid())
  numero       String      @unique
  fecha        DateTime?   @default(now()) @db.Timestamp(6)
  companyId    String?     @map("company_id")
  condicionIva String?     @default("RI") @map("condicion_iva")
  subtotal     Float
  iva          Float
  percepciones Float?      @default(0)
  total        Float
  metodoPago   String?     @default("TRANSFERENCIA") @map("metodo_pago")
  estado       String?     @default("PENDIENTE")
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  items        VentaItem[]
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("ventas")
}

model VentaItem {
  id          String  @id @default(uuid())
  ventaId     String? @map("venta_id")
  descripcion String
  cantidad    Int
  precioUnit  Float   @map("precio_unit")
  subtotal    Float
  venta       Venta?  @relation(fields: [ventaId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("venta_items")
}

model Compra {
  id           String       @id @default(uuid())
  proveedor    String
  cuit         String?
  numero       String?
  fecha        DateTime?    @default(now()) @db.Timestamp(6)
  subtotal     Float
  iva          Float
  percepciones Float?       @default(0)
  total        Float
  metodoPago   String?      @default("EFECTIVO") @map("metodo_pago")
  categoria    String?      @default("OTROS")
  createdAt    DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime?    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  items        CompraItem[]

  @@map("compras")
}

model CompraItem {
  id          String  @id @default(uuid())
  compraId    String? @map("compra_id")
  descripcion String
  cantidad    Int
  precioUnit  Float   @map("precio_unit")
  subtotal    Float
  compra      Compra? @relation(fields: [compraId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("compra_items")
}

model CajaMovimiento {
  id         String    @id @default(uuid())
  fecha      DateTime? @default(now()) @db.Timestamp(6)
  tipo       String
  monto      Float
  concepto   String
  referencia String?
  metodo     String?   @default("EFECTIVO")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("caja_movimientos")
}

model asistencias_clase {
  id        String   @id
  alumno_id String
  modulo_id String
  curso_id  String
  check_in  DateTime @default(now())
  users     User     @relation(fields: [alumno_id], references: [id])
  modulos   Modulo   @relation(fields: [modulo_id], references: [id])

  @@unique([alumno_id, modulo_id])
  @@index([curso_id])
}

model evidencias {
  id                                   String           @id
  tarea_id                             String
  alumno_id                            String
  foto_url                             String
  comentario                           String?
  estado                               EstadoEvidencia  @default(PENDIENTE)
  feedback                             String?
  evaluador_id                         String?
  uploaded_at                          DateTime         @default(now())
  updated_at                           DateTime
  users_evidencias_alumno_idTousers    User             @relation("evidencias_alumno_idTousers", fields: [alumno_id], references: [id])
  users_evidencias_evaluador_idTousers User?            @relation("evidencias_evaluador_idTousers", fields: [evaluador_id], references: [id])
  tareas_practicas                     tareas_practicas @relation(fields: [tarea_id], references: [id], onDelete: Cascade)

  @@index([alumno_id])
  @@index([tarea_id])
}

model modulos_completados {
  id         String   @id
  alumno_id  String
  modulo_id  String
  curso_id   String
  created_at DateTime @default(now())

  @@unique([alumno_id, modulo_id])
  @@index([alumno_id, curso_id])
}

model tareas_practicas {
  id            String       @id
  modulo_id     String
  descripcion   String
  requiere_foto Boolean      @default(true)
  created_at    DateTime     @default(now())
  updated_at    DateTime
  evidencias    evidencias[]
  modulos       Modulo       @relation(fields: [modulo_id], references: [id], onDelete: Cascade)
}

enum EstadoEvidencia {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoInscripcion {
  NO_INICIADO
  EN_PROGRESO
  COMPLETADO
  APROBADO
  REPROBADO
}

enum TipoModulo {
  TEORIA
  QUIZ
  PRACTICA
}

enum UserRole {
  SUPER_ADMIN
  INSTRUCTOR
  ALUMNO
}
